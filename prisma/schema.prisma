generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StatusProses {
  id         String   @id @default(cuid())
  kode       String   @unique
  nama       String
  urutan     Int
  warna      String   @default("#d4af37")
  icon       String?
  keterangan String?
  isKhusus   Boolean  @default(false)
  isFinal    Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model JenisSurat {
  id              String       @id @default(cuid())
  kode            String       @unique
  nama            String
  deskripsi       String?
  butuhPengukuran Boolean      @default(true)
  butuhTtdCamat   Boolean      @default(false)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  permohonan      Permohonan[]
}

model StatusPenguasaan {
  id        String   @id @default(cuid())
  kode      String   @unique
  nama      String
  deskripsi String?
  urutan    Int      @default(0)
  warna     String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  password         String
  name             String
  role             String          @default("PETUGAS")
  phone            String?
  position         String?
  nip              String?
  avatar           String?
  isActive         Boolean         @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  auditLogs        AuditLog[]
  notifikasi       Notifikasi[]
  permohonanDibuat Permohonan[]
  riwayatProses    RiwayatProses[]
}

model Permohonan {
  id                  String            @id @default(cuid())
  nomorRegister       String            @unique
  jenisSuratId        String
  pemohonNik          String
  pemohonNama         String
  pemohonTempatLahir  String?
  pemohonTanggalLahir String?
  pemohonAlamat       String?
  pemohonRt           String?
  pemohonRw           String?
  pemohonHp           String?
  pemohonEmail        String?
  lokasiTanah         String?
  tanahRt             String?
  tanahRw             String?
  luasTanah           String?
  batasUtara          String?
  batasSelatan        String?
  batasTimur          String?
  batasBarat          String?
  statusPenguasaan    String?
  keperluan           String?
  statusSaatIni       String            @default("PENGAJUAN")
  alasanDitolak       String?
  catatan             String?
  prioritas           String            @default("NORMAL")
  createdBy           String
  updatedBy           String?
  qrToken             String?
  tanggalSelesai      DateTime?
  estimasiSelesai     DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  arsip               ArsipSuratTanah?
  biaya               BiayaOperasional?
  dokumen             Dokumen[]
  notifikasi          Notifikasi[]
  creator             User              @relation(fields: [createdBy], references: [id])
  jenisSurat          JenisSurat        @relation(fields: [jenisSuratId], references: [id])
  riwayat             RiwayatProses[]
  riwayatTanah        RiwayatTanah[]
}

model ArsipSuratTanah {
  id              String     @id @default(cuid())
  permohonanId    String     @unique
  nomorSurat      String?
  tanggalTerbit   DateTime?
  pejabatPenerbit String?
  jabatanPejabat  String?
  nomorLembar     String?
  lokasiArsip     String?
  catatan         String?
  namaFile        String
  filePath        String
  ukuran          Int?
  mimeType        String?
  fileHash        String?
  uploadedBy      String
  uploadedAt      DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  permohonan      Permohonan @relation(fields: [permohonanId], references: [id], onDelete: Cascade)

  @@index([tanggalTerbit])
  @@index([pejabatPenerbit])
}

model BiayaOperasional {
  id                String     @id @default(cuid())
  permohonanId      String     @unique
  nominal           Int
  keterangan        String?
  statusPembayaran  String     @default("BELUM_LUNAS")
  metodePembayaran  String?
  tanggalJatuhTempo DateTime?
  tanggalBayar      DateTime?
  nomorKwitansi     String?    @unique
  diterimaOleh      String?
  catatan           String?
  createdBy         String
  updatedBy         String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  permohonan        Permohonan @relation(fields: [permohonanId], references: [id], onDelete: Cascade)

  @@index([statusPembayaran])
  @@index([tanggalBayar])
  @@index([nomorKwitansi])
}

model RiwayatTanah {
  id                String     @id @default(cuid())
  permohonanId      String
  urutan            Int        @default(1)
  tahun             String?
  pemilikSebelumnya String?
  hubunganPemilik   String?
  caraPerolehan     String?
  noDokumen         String?
  keterangan        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  permohonan        Permohonan @relation(fields: [permohonanId], references: [id], onDelete: Cascade)

  @@index([permohonanId])
  @@index([urutan])
}

model Dokumen {
  id               String     @id @default(cuid())
  permohonanId     String
  jenisDokumen     String
  namaFile         String
  filePath         String
  ukuran           Int?
  mimeType         String?
  uploadedBy       String     @default("PETUGAS")
  isRevisionUpload Boolean    @default(false)
  catatanPemohon   String?
  createdAt        DateTime   @default(now())
  permohonan       Permohonan @relation(fields: [permohonanId], references: [id], onDelete: Cascade)
}

model RiwayatProses {
  id           String     @id @default(cuid())
  permohonanId String
  statusKode   String
  statusNama   String
  catatan      String?
  petugasId    String
  createdAt    DateTime   @default(now())
  permohonan   Permohonan @relation(fields: [permohonanId], references: [id], onDelete: Cascade)
  petugas      User       @relation(fields: [petugasId], references: [id])
}

model Notifikasi {
  id           String      @id @default(cuid())
  permohonanId String?
  userId       String?
  judul        String
  pesan        String
  tipe         String      @default("INFO")
  dibaca       Boolean     @default(false)
  createdAt    DateTime    @default(now())
  permohonan   Permohonan? @relation(fields: [permohonanId], references: [id])
  user         User?       @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  userRole  String?
  aksi      String
  modul     String
  entitasId String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
